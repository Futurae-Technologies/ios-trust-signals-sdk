,"type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/Futurae-Technologies\/ios-trust-signals-sdk.git\", from: \"0.1.0\")","]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Or in Xcode: "},{"type":"strong","inlineContent":[{"text":"File → Add Package Dependencies…","type":"text"}]},{"type":"text","text":" and enter the repository URL."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then import the module:"}]},{"syntax":"swift","type":"codeListing","code":["import TrustSignals"]},{"type":"heading","level":3,"anchor":"Infoplist-Configuration","text":"Info.plist Configuration"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the following keys to your app’s "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" for the permission-driven collectors you wish to use:"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Key","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Required for","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSLocationWhenInUseUsageDescription"}]}],[{"type":"paragraph","inlineContent":[{"text":"Location collector","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSLocationAlwaysAndWhenInUseUsageDescription"}]}],[{"type":"paragraph","inlineContent":[{"text":"Background location","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSBluetoothAlwaysUsageDescription"}]}],[{"type":"paragraph","inlineContent":[{"text":"Bluetooth collector","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSLocalNetworkUsageDescription"}]}],[{"type":"paragraph","inlineContent":[{"text":"Nearby devices collector","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSBonjourServices"}]}],[{"type":"paragraph","inlineContent":[{"text":"Nearby devices collector (list service types)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSMotionUsageDescription"}]}],[{"type":"paragraph","inlineContent":[{"text":"Motion collector (future)","type":"text"}]}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For WiFi scanning, also add the "},{"type":"strong","inlineContent":[{"text":"Access WiFi Information","type":"text"}]},{"type":"text","text":" entitlement in Xcode → Signing & Capabilities."}]},{"type":"heading","level":2,"anchor":"Quickstart","text":"Quickstart"},{"type":"heading","level":3,"anchor":"1-Initialize-the-SDK","text":"1. Initialize the SDK"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call "},{"type":"reference","identifier":"doc:\/\/ios-sdk-sensor.TrustSignals\/documentation\/TrustSignals\/TrustSignalsSDK\/initialize(_:)","isActive":true},{"type":"text","text":" once on app launch — it is idempotent and can be called again to reconfigure."}]},{"syntax":"swift","type":"codeListing","code":["import TrustSignals","import UIKit","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        Task {","            await TrustSignalsSDK.initialize(","                TSConfiguration(","                    serverURL: URL(string: \"https:\/\/trustsignals.example.com\")!,","                    appID: \"your-app-id\"","                )","            )","        }","","        return true","    }","}"]},{"type":"heading","level":3,"anchor":"2-Collect-signals","text":"2. Collect signals"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Trigger a one-shot collection that returns a "},{"type":"reference","identifier":"doc:\/\/ios-sdk-sensor.TrustSignals\/documentation\/TrustSignals\/TSCollection","isActive":true},{"type":"text","text":" without uploading:"}]},{"syntax":"swift","type":"codeListing","code":["let collection = try await TrustSignalsSDK.collect()","print(collection.observation.bleScan?.scanResults.count ?? 0, \"BLE devices found\")"]},{"type":"heading","level":3,"anchor":"3-Collect-and-upload","text":"3. Collect and upload"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Collect signals and upload them to the Collection API using your OAuth2 access token:"}]},{"syntax":"swift","type":"codeListing","code":["let collection = try await TrustSignalsSDK.collectAndUpload(","    accessToken: \"your-oauth2-access-token\",","    accountID: \"user-account-id\"",")"]},{"type":"heading","level":3,"anchor":"4-Schedule-recurring-collections","text":"4. Schedule recurring collections"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set up automatic collection and upload on a fixed interval:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Collect and upload every 60 seconds","await TrustSignalsSDK.scheduleCollections(","    interval: .seconds(60),","    accessToken: \"your-oauth2-access-token\",","    accountID: \"user-account-id\"",")","","\/\/ Cancel: pass .zero interval","await TrustSignalsSDK.scheduleCollections(","    interval: .zero,","    accessToken: \"\",","    accountID: \"\"",")"]},{"type":"heading","level":3,"anchor":"5-Observe-collections-in-real-time","text":"5. Observe collections in real time"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Subscribe to a stream of all emitted collections (on-demand and scheduled):"}]},{"syntax":"swift","type":"codeListing","code":["Task {","    for await collection in await TrustSignalsSDK.collections {","        print(\"New collection: \\(collection.collectionId)\")","    }","}"]},{"type":"heading","level":3,"anchor":"6-Error-handling","text":"6. Error handling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Register a handler for errors during scheduled background collections:"}]},{"syntax":"swift",