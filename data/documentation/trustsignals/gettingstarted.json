{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"text":"This guide walks you through adding the TrustSignals package, configuring it, and performing your first signal collection.","type":"text"}]},{"level":2,"text":"Setup","type":"heading","anchor":"Setup"},{"level":3,"text":"Requirements","type":"heading","anchor":"Requirements"},{"header":"row","rows":[[[{"inlineContent":[{"text":"Requirement","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Minimum","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"iOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"16.0+","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Swift","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"6.0+","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Xcode","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"16+","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"anchor":"Swift-Package-Manager","type":"heading","text":"Swift Package Manager","level":3},{"type":"paragraph","inlineContent":[{"text":"Add the package dependency to your ","type":"text"},{"code":"Package.swift","type":"codeVoice"},{"text":" or via Xcode’s package manager:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/Futurae-Technologies\/ios-trust-signals-sdk.git\", from: \"0.1.0\")","]"]},{"type":"paragraph","inlineContent":[{"text":"Or in Xcode: ","type":"text"},{"inlineContent":[{"text":"File → Add Package Dependencies…","type":"text"}],"type":"strong"},{"text":" and enter the repository URL.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Then import the module:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["import TrustSignals"]},{"anchor":"Infoplist-Configuration","type":"heading","text":"