ignals\/documentation\/TrustSignals\/TSCollection"},{"type":"text","text":" without uploading:"}]},{"syntax":"swift","type":"codeListing","code":["let collection = try await TrustSignalsSDK.collect()","print(collection.observation.bleScan?.scanResults.count ?? 0, \"BLE devices found\")"]},{"anchor":"3-Collect-and-upload","type":"heading","text":"3. Collect and upload","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Collect signals and upload them to the Collection API using your OAuth2 access token:"}]},{"syntax":"swift","type":"codeListing","code":["let collection = try await TrustSignalsSDK.collectAndUpload(","    accessToken: \"your-oauth2-access-token\",","    accountID: \"user-account-id\"",")"]},{"anchor":"4-Schedule-recurring-collections","type":"heading","text":"4. Schedule recurring collections","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Set up automatic collection and upload on a fixed interval:"}]},{"syntax":"swift","type":"codeListing","code":["\/\/ Collect and upload every 60 seconds","await TrustSignalsSDK.scheduleCollections(","    interval: .seconds(60),","    accessToken: \"your-oauth2-access-token\",","    accountID: \"user-account-id\"",")","","\/\/ Cancel: pass .zero interval","await TrustSignalsSDK.scheduleCollections(","    interval: .zero,","    accessToken: \"\",","    accountID: \"\"",")"]},{"anchor":"5-Observe-collections-in-real-time","type":"heading","text":"5. Observe collections in real time","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Subscribe to a stream of all emitted collections (on-demand and scheduled):"}]},{"syntax":"swift","type":"codeListing","code":["Task {","    for await collection in await TrustSignalsSDK.collections {","        print(\"New collection: \\(collection.collectionId)\")","    }","}"]},{"anchor":"6-Error-handling","type":"heading","text":"6. Error handling","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Registe