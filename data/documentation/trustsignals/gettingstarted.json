t service types)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSMotionUsageDescription"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Motion collector (future)"}]}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"For WiFi scanning, also add the "},{"type":"strong","inlineContent":[{"type":"text","text":"Access WiFi Information"}]},{"type":"text","text":" entitlement in Xcode → Signing & Capabilities."}],"type":"paragraph"},{"type":"heading","text":"Bonjour services","anchor":"Bonjour-services","level":3},{"type":"paragraph","inlineContent":[{"text":"The nearby-devices collector can only browse for Bonjour service types that are","type":"text"},{"type":"text","text":" "},{"type":"text","text":"explicitly declared under "},{"type":"codeVoice","code":"NSBonjourServices"},{"type":"text","text":" — iOS silently skips any type not"},{"type":"text","text":" "},{"text":"listed. To match the SDK’s full coverage, add:","type":"text"}]},{"code":["<key>NSBonjourServices<\/key>","<array>","    <string>_smb._tcp.<\/string>","    <string>_privet._tcp.<\/string>","    <string>_device-info._tcp.<\/string>","    <string>_sftp-ssh._tcp.<\/string>","    <string>_airplay._tcp.<\/string>","    <string>_scanner._tcp.<\/string>","    <string>_mediaremotetv._tcp.<\/string>","    <string>_rdlink._tcp.<\/string>","    <string>_rfb._tcp.<\/string>","    <string>_uscan._tcp.<\/string>","    <string>_companion-link._tcp.<\/string>","    <string>_apple-mobdev2._tcp.<\/string>","    <string>_b._dns-sd._udp.<\/string>","    <string>_afpovertcp._tcp.<\/string>","    <string>_nfs._tcp.<\/string>","    <string>_webdav._tcp.<\/string>","    <string>_ftp._tcp.<\/string>","    <string>_ssh._tcp.<\/string>","    <string>_eppc._tcp.<\/string>","    <string>_http._tcp.<\/string>","    <string>_telnet._tcp.<\/string>","    <string>_printer._tcp.<\/string>","    <string>_ipp._tcp.<\/string>","    <string>_pdl-datastream._tcp.<\/string>","    <string>_riousbprint._tcp.<\/string>","    <string>_daap._tcp.<\/string>","    <string>_dpap._tcp.<\/string>","    <string>_ichat._tcp.<\/string>","    <string>_presence._tcp.<\/string>","    <string>_ica-networking._tcp.<\/string>","    <string>_airport._tcp.<\/string>","    <string>_xserveraid._tcp.<\/string>","    <string>_distcc._tcp.<\/string>","    <string>_apple-sasl._tcp.<\/string>","    <string>_workstation._tcp.<\/string>","    <string>_servermgr._tcp.<\/string>","    <string>_raop._tcp.<\/string>","    <string>_xcs2p._tcp.<\/string>","<\/array>"],"syntax":"xml","type":"codeListing"},{"inlineContent":[{"type":"reference","identifier":"doc:\/\/ios-sdk-sensor.TrustSignals\/documentation\/TrustSignals\/TSConfiguration","isActive":true},{"type":"text","text":" reads this list by default via"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/ios-sdk-sensor.TrustSignals\/documentation\/TrustSignals\/TSConfiguration\/bonjourServicesFromList()","isActive":true},{"type":"text","text":"; pass an explicit"},{"type":"text","text":" "},{"type":"codeVoice","code":"bonjourServices:"},{"type":"text","text":" array to browse a narrower set."}],"type":"paragraph"},{"type":"heading","text":"Quickstart","anchor":"Quickstart","level":2},{"type":"heading","text":"1. Initialize the SDK","anchor":"1-Initialize-the-SDK","level":3},{"inlineContent":[{"type":"text","text":"Call "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ios-sdk-sensor.TrustSignals\/documentation\/TrustSignals\/TrustSignalsSDK\/initialize(_:)"},{"type":"text","text":" once on app launch — it is idempotent and can be called again to reconfigure."}],"type":"paragraph"},{"code":["import TrustSignals","import UIKit","","@main","class AppDelegate: UIResponder, UIApplicationDelegate {","","    func application(","        _ application: UIApplication,","        didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?","    ) -> Bool {","","        Task {","            await TrustSignalsSDK.initialize(","                TSConfiguration(","                    serverURL: URL(string: \"https:\/\/trustsignals.example.com\")!,","                    appID: \"your-app-id\"","                )","            )","        }","","        return true","    }","}"],"syntax":"swift","type":"codeListing"},{"level":3,"text":"2. Collect signals","anchor":"2-Collect-signals","type":"heading"},{"inlineContent":[{"type":"text","text":"Trigger a one-shot collection that returns a "},{"type":"reference","identifier":"doc:\/\/ios-sdk-sensor.TrustSignals\/documentation\/TrustSignals\/TSCollection","isActive":true},{"type":"text","text":" without uploading:"}],"type":"paragraph"},{"code":["let collection = try await TrustSignalsSDK.collect()","print(collection.observation.bleScan?.scanResults.count ?? 0, \"BLE devices found\")"],"syntax":"swift","type":"codeListing"},{"level":3,"text":"3. Collect and upload","anchor":"3-Collect-and-upload","type":"heading"},{"inlineContent":[{"type":"text","text":"Collect signals and upload them to the Collection API using your OAuth2 access token:"}],"type":"paragraph"},{"code":["let collection = try await TrustSignalsSDK.collectAndUpload(","    accessToken: \"your-oauth2-access-token\",","    accountID: \"user-account-id\"",")"],"syntax":"swift","type":"codeListing"},{"level":3,"text":"4. Schedule recurring collections","anchor":"4-Schedule-recurring-collections","type":"heading"},{"inlineContent":[{"type":"text","text":"Set up automatic collection and upload on a fixed interval:"}],"type":"paragraph"},{"code":["\/\/ Collect and upload every 60 seconds","await TrustSignalsSDK.scheduleCollections(","    interval: .seconds(60),","    accessToken: \"your-oauth2-access-token\",","    accountID: \"user-account-id\"",")","","\/\/ Cancel: pass .zero interval","await TrustSignalsSDK.scheduleCollections(","    interval: .zero,","    accessToken: \"\",","    accountID: \"\"",")"],"syntax":"swift","type":"codeListing"},{"level":3,"text":"5. Observe collections in real time","anchor":"5-Observe-collections-in-real-time","type":"heading"},{"inlineContent":[{"type":"text","text":"Subscribe to a stream of all emitted collections (on-demand and scheduled):"}],"type":"paragraph"},{"code":["Task {","    for await collection in await TrustSignalsSDK.collections {","        print(\"New collection: \\(collection.collectionId)\")","    }","}"],"syntax":"swift","type":"codeListing"},{"level":3,"text":"6. Error handling","anchor":"6-Error-handling","type":"heading"},{"inlineContent":[{"type":"text","text":"Register a handler for errors during scheduled background collections:"}],"type":"paragraph"},{"code":["await TrustSignalsSDK.registerErrorHandler { accountID, error in","    print(\"Collection failed for \\(accountID): \\(error)\")","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"For on-demand calls, errors are thrown directly:"}],"type":"paragraph"},{"code":["do {","    let collection = try await TrustSignalsSDK.collect()","} catch TSError.notStarted {","    \/\/ SDK not initialized — call initialize(_:) first","} catch TSError.collectionTimedOut {","    \/\/ Collection exceeded 20s timeout","}"],"syntax":"swift","type":"codeListing"},{"name":"Note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The error handler may be invoked off the main thread. Hop to"},{"type":"text","text":" "},{"type":"codeVoice","code":"@MainActor"},{"type":"text","text":" before touching UI."}]}],"style":"note","type":"aside"},{"level":4,"text":"Error behaviour summary","anchor":"Error-behaviour-summary","type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Error type"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Retry"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Where it surfaces"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Transport failure — DNS\/TLS\/